router bgp {{ custom_fields.ebgp_asn }}
  bgp router-id {{ primary_ip4 }}
  maximum-pahts ebgp 4
  redistribute imported-bgp
{% for peer in device_context.ebgp_peers | default([]) %}
  neighbor {{ peer.remote_ip }} remote-as {{ peer.remote-as }}
  neighbor {{ peer.remote_ip }} no shutdown
{% endfor %}
